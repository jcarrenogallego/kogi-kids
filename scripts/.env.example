# Runway API Configuration
# Get your API key from: https://app.runwayml.com/settings/api-keys
RUNWAY_API_KEY=rw_your_api_key_here

# API Settings
RUNWAY_API_BASE_URL=https://api.runwayml.com/v1

# Default Model (gen4_turbo or gen4.5)
RUNWAY_DEFAULT_MODEL=gen4_turbo

# Default Video Duration (seconds, 5-10)
RUNWAY_DEFAULT_DURATION=10

# Timeout Settings (seconds)
RUNWAY_TIMEOUT=300
RUNWAY_POLL_INTERVAL=5

# Budget Limits (USD)
RUNWAY_MAX_BUDGET=50.00
RUNWAY_WARN_THRESHOLD=40.00

# Project Paths (relative to project root)
STORIES_PATH=stories
RENDERS_PATH=renders
ANIMATIONS_PATH=animations
